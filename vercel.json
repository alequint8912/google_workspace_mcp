{
  "$schema": "https://openapi.schema.vercel.com/vercel.json",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/mcp/(.*)",
      "dest": "/api/index.py"
    }
  ]
}